{
  "mcpServers": {
    "google_workspace": {
      "command": "uvx",
      "args": [
        "workspace-mcp",
        "--tools",
        "drive",
        "docs",
        "slides"
      ],
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "YOUR_GOOGLE_OAUTH_CLIENT_ID",
        "GOOGLE_OAUTH_CLIENT_SECRET": "YOUR_GOOGLE_OAUTH_CLIENT_SECRET",
        "USER_GOOGLE_EMAIL": "your.email@example.com"
      }
    },
    "atlassian": {
      "url": "https://mcp.atlassian.com/v1/mcp"
    }
  }
}
